%% GuitarLab architecture (current implementation)
graph TD
    subgraph Client[Client]
        User[User]
        Browser[Browser]
    end

    subgraph Frontend[Frontend]
        ReactApp[React + Vite UI]
        ViteProxy[Vite /api proxy]
    end

    subgraph Backend[Backend (FastAPI)]
        ChatRoute[/POST /api/chat/]
        UploadRoute[/POST /api/upload/]
        AdvanceRoute[/POST /api/chat/advance-step/]
        AgentRouter[Agent Router]
        Luthier[Master Luthier Agent]
        ToneGuru[Tone Guru Agent]
        Sessions[(In-memory sessions)]
    end

    subgraph KnowledgeAndAI[Knowledge + AI]
        KB[(electronics_knowledge_base.json)]
        Uploads[(backend/uploads)]
        Gemini[Google Gemini API]
    end

    User --> Browser
    Browser --> ReactApp
    ReactApp --> ViteProxy
    ViteProxy --> ChatRoute
    ViteProxy --> UploadRoute
    ViteProxy --> AdvanceRoute

    ChatRoute --> AgentRouter
    AgentRouter --> Luthier
    AgentRouter --> ToneGuru

    Luthier --> Sessions
    ToneGuru --> Sessions

    Luthier --> KB
    ToneGuru --> KB

    Luthier --> Gemini
    ToneGuru --> Gemini

    UploadRoute --> Uploads